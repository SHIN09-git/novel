{
  "name": "novel-director",
  "version": "0.1.0",
  "productName": "Novel Director",
  "description": "AI long-form novel creation management desktop MVP",
  "license": "MIT",
  "author": "Novel Director contributors",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc --noEmit && electron-vite build",
    "dist:win": "node scripts/run-dist-win.mjs",
    "smoke": "set NOVEL_DIRECTOR_SMOKE_TEST=1&& electron-vite preview",
    "smoke:packaged": "node scripts/smoke-packaged-app.mjs",
    "rc:fixture": "node scripts/rc-regression.mjs",
    "test": "node scripts/run-tests.mjs",
    "test:single": "node scripts/run-tests.mjs",
    "typecheck": "tsc --noEmit",
    "preview": "electron-vite preview"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "better-sqlite3": "^12.9.0",
    "electron-vite": "^4.0.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "build": {
    "appId": "com.noveldirector.workbench",
    "productName": "Novel Director",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "files": [
      "out/**/*",
      "package.json",
      "LICENSE",
      "README.md"
    ],
    "asar": true,
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName} Setup ${version}.${ext}"
    },
    "nsis": {
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Novel Director",
      "deleteAppDataOnUninstall": false
    }
  }
}
